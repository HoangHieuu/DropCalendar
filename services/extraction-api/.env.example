# The service loads repository-root and service-local .env files for local work.
# Copy ../../.env.example to ../../.env and fill only the values needed by the
# selected loopback or hosted mode. Never commit the populated file.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=SnapCal
SNAPCAL_EXTRACTION_HOST=127.0.0.1
SNAPCAL_EXTRACTION_PORT=8765

# Hosted v2 mode. Keep disabled for the loopback v1 helper.
SNAPCAL_PRODUCTION_MODE=0
SNAPCAL_ENVIRONMENT=staging
DATABASE_URL=
SNAPCAL_SESSION_SIGNING_KEY=
SNAPCAL_INPUT_HMAC_KEY=
SNAPCAL_API_BASE_URL=https://staging-api.example.com
SNAPCAL_WEB_BASE_URL=https://www.example.com
SNAPCAL_PROVIDER_MONTHLY_BUDGET_USD=25
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
GOOGLE_CLOUD_PROJECT=
SNAPCAL_TASKS_LOCATION=asia-southeast1
SNAPCAL_TASKS_QUEUE=snapcal-background
SNAPCAL_TASKS_SERVICE_ACCOUNT=

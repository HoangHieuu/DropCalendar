# The service automatically loads the repository-root .env file.
# Copy ../../.env.example to ../../.env and fill only the private key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=SnapCal
SNAPCAL_EXTRACTION_HOST=127.0.0.1
SNAPCAL_EXTRACTION_PORT=8765

# OpenRouter credentials
# Copy this file to .env and fill in your real key. Never commit .env.
OPENROUTER_API_KEY=

# OpenRouter API and model
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Optional OpenRouter app attribution
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=SnapCal

# Google Desktop OAuth token broker
# Keep the downloaded JSON outside this repository and point to it here.
GOOGLE_OAUTH_CREDENTIALS_FILE=

# Local SnapCal extraction service
SNAPCAL_EXTRACTION_HOST=127.0.0.1
SNAPCAL_EXTRACTION_PORT=8765

# Paid-beta hosted API (staging/production only)
SNAPCAL_PRODUCTION_MODE=0
SNAPCAL_ENVIRONMENT=staging
DATABASE_URL=
SNAPCAL_SESSION_SIGNING_KEY=
SNAPCAL_INPUT_HMAC_KEY=
SNAPCAL_API_BASE_URL=https://staging-api.example.com
SNAPCAL_WEB_BASE_URL=https://www.example.com
SNAPCAL_PROVIDER_MONTHLY_BUDGET_USD=25

# Paddle (sandbox for staging, production for production)
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=

# Cloud Tasks and authenticated maintenance, Singapore only
GOOGLE_CLOUD_PROJECT=
SNAPCAL_TASKS_LOCATION=asia-southeast1
SNAPCAL_TASKS_QUEUE=snapcal-background
SNAPCAL_TASKS_SERVICE_ACCOUNT=

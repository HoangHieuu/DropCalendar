# OpenRouter credentials
# Copy this file to .env and fill in your real key. Never commit .env.
OPENROUTER_API_KEY=

# OpenRouter API and model
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Optional OpenRouter app attribution
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=SnapCal

# Local SnapCal extraction service
SNAPCAL_EXTRACTION_HOST=127.0.0.1
SNAPCAL_EXTRACTION_PORT=8765
